# Flask Core
FLASK_SECRET_KEY=super_secret_takeout_key_replace_me_in_prod

# CSRF Protection (can be same as FLASK_SECRET_KEY or a separate random string)
WTF_CSRF_SECRET_KEY=replace_with_a_random_secret_key

# Fernet Encryption Key (for target account passwords stored in DB)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# Google OAuth 2.0 Credentials
# Get these from Google Cloud Console -> APIs & Services -> Credentials
GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
